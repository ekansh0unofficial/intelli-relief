# IntelliRelief Environment Variables
# Copy this file to .env and update with your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_USER=intellirelief
POSTGRES_PASSWORD=intellirelief_dev_2026
POSTGRES_DB=intellirelief_db

# Full database URL (auto-constructed in docker-compose)
# DATABASE_URL=postgresql://intellirelief:intellirelief_dev_2026@localhost:5432/intellirelief_db

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# BACKEND CONFIGURATION
# ============================================
# Environment: development, staging, production
ENVIRONMENT=development

# Secret key for JWT tokens (CHANGE THIS IN PRODUCTION!)
# Generate with: openssl rand -hex 32
SECRET_KEY=09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80

# ============================================
# FRONTEND CONFIGURATION
# ============================================
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws

# ============================================
# EXTERNAL API KEYS
# ============================================
# OpenWeatherMap API Key
# Get your free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Mapbox Token (Optional - Leaflet works without it)
# Get your token at: https://account.mapbox.com/
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# ============================================
# EMAIL CONFIGURATION (For Notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@intellirelief.com

# ============================================
# SMS CONFIGURATION (Optional)
# ============================================
# Twilio or similar service
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your_account_sid
SMS_AUTH_TOKEN=your_auth_token
SMS_FROM_NUMBER=+1234567890

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FILE=/app/logs/intellirelief.log

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# Password requirements
MIN_PASSWORD_LENGTH=8

# Session timeout (minutes)
SESSION_TIMEOUT_MINUTES=30

# ============================================
# DEVELOPMENT TOOLS
# ============================================
# Enable debug mode (DO NOT USE IN PRODUCTION)
DEBUG=true

# Enable SQL query logging
SQL_ECHO=false

# Enable hot reload
HOT_RELOAD=true
